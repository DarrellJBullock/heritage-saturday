# Heritage Saturday — root .env.example
# Copy to .env for use with docker-compose.yml. apps/api reads its own .env
# (see apps/api/.env.example) but the values below MUST match this compose stack.

# --- Postgres (docker-compose `postgres` service) ---
POSTGRES_USER=heritage
POSTGRES_PASSWORD=heritage
POSTGRES_DB=heritage_saturday
POSTGRES_PORT=5433
# ^ mapped to container port 5432; host side is 5433 to avoid colliding with a Postgres
#   instance you may already be running locally on 5432 (see docker-compose.yml comment).

# --- Redis (docker-compose `redis` service) — reserved for apps/worker (BullMQ), ---
# --- not consumed by apps/api in Capability 1 since simulation runs synchronously. ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- apps/api ---
# Full connection string apps/api/.env needs; must match Postgres values above.
DATABASE_URL="postgresql://heritage:heritage@localhost:5433/heritage_saturday?schema=public"
