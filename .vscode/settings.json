{
  // Use the repo's pinned TypeScript (5.4.5) instead of the editor's bundled copy.
  // Without this the editor type-checks with a much newer tsc and reports errors that
  // `npm run typecheck` does not — e.g. the `moduleResolution: node` (node10) and
  // `baseUrl` deprecations, which are only errors in TS 6+/7.
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true
}
