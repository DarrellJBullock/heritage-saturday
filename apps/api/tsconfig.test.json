{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist-test",
    "rootDir": ".",
    "incremental": false
  },
  // The auth middleware and the round-robin generator, plus their tests. Deliberately NOT all
  // of `src`: the rest of the API imports @prisma/client, whose types exist only after
  // `prisma generate`. Both included files are Prisma-free, so `npm test` still runs without a
  // generated client or a database.
  "include": ["src/common/auth", "src/schedule/round-robin.ts", "test/*.test.ts"]
}
