# Heritage Saturday — apps/api local environment example
# Copy to .env and adjust as needed. Values below match the Postgres service
# defined in the project's Docker Compose setup (see company-docs/vision.md).
#
# NOTE: host port is 5433, not Postgres's default 5432 — see docker-compose.yml comment
# (avoids colliding with a Postgres instance devs may already be running locally on 5432).

DATABASE_URL="postgresql://heritage:heritage@localhost:5433/heritage_saturday?schema=public"

# Redis connection for BullMQ. Not consumed by apps/api in Capability 1 (simulation
# runs synchronously per company-docs/architecture.md §6) — reserved for apps/worker,
# included here so the var is documented ahead of time.
REDIS_URL="redis://localhost:6379"

# --- DEPLOYMENT LOCK (not an identity system) ---
# Auth is a stub: the API trusts an `x-user-id` header, so any caller can be any user.
# On a reachable host the API must therefore be gated behind a shared secret that only
# apps/web's server-side proxy knows. Unset here so local development stays frictionless.
#
# With NODE_ENV=production, the API REFUSES TO START unless this is set — a forgotten env
# var must not silently publish an open API. Override deliberately with
# ALLOW_INSECURE_NO_API_KEY=true (the docker-compose `api` service does; CI does not — it
# runs the containers with a real secret so the gate is exercised the way it ships).
# API_SHARED_SECRET="generate-a-long-random-string"

# Comma-separated browser origins allowed by CORS. Leave unset: with apps/web proxying
# every browser request server-side, nothing calls this API cross-origin.
# WEB_ORIGIN="https://your-app.vercel.app"
