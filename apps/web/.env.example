# Heritage Saturday — apps/web local environment example
# Copy to .env.local and adjust as needed.

# Base URL of the running apps/api instance, used by SERVER-SIDE fetches only
# (Server Components, and the /api/proxy route). Read at runtime.
# Deliberately not NEXT_PUBLIC_*: on a deployment this may be an internal hostname, and it
# is paired with API_SHARED_SECRET, which must never reach a client bundle.
API_URL="http://localhost:3001"

# Must match apps/api's API_SHARED_SECRET when that is set. The browser never sees it:
# client-side requests go to this app's own /api/proxy/* route, which attaches it.
# API_SHARED_SECRET="generate-a-long-random-string"

# --- AUTH (Auth.js) ---
# Signs and encrypts the session cookie. REQUIRED — Auth.js refuses to start without it.
# Generate one with: openssl rand -base64 32
# Rotating this invalidates every existing session.
AUTH_SECRET="generate-a-long-random-string"

# Google OAuth client, from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be exactly:
#   http://localhost:3000/api/auth/callback/google
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# --- DEV LOGIN (never on a deployed host) ---
# Registers a password-less "sign in as dev-user-1" button, so the app is usable before the
# Google credentials above exist. dev-user-1 is a seeded fixture (apps/api/prisma/seed.ts).
#
# Ignored unless NODE_ENV is not "production", and apps/web REFUSES TO START if it is set to
# true with NODE_ENV=production — a bypass must fail loudly, not silently do nothing. That is
# also why the `web` docker image (which sets NODE_ENV=production) can never enable it.
ALLOW_DEV_LOGIN="true"
