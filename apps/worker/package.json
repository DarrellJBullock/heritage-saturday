{
  "name": "@heritage-saturday/worker",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "start:dev": "ts-node src/index.ts",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js",
    "smoke": "node test/smoke.mjs"
  },
  "dependencies": {
    "@heritage-saturday/shared": "*",
    "@heritage-saturday/simulation-engine": "*",
    "bullmq": "^5.34.6"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "ts-node": "^10.9.2"
  }
}
